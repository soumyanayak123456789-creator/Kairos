# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Get these from Google Cloud Console → APIs & Services → Credentials →
# your OAuth 2.0 Client ID (type: Web application).

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must EXACTLY match an Authorized redirect URI on that OAuth client.
# For local testing keep this default.
OAUTH_REDIRECT_URI=http://localhost:8080/oauth2callback

# GCP project that owns the Firestore database AND bills Vertex AI (Gemini).
# If omitted, Firestore tries to infer it from ADC, but Vertex AI requires it.
GOOGLE_CLOUD_PROJECT=project-2fa6ca07-83db-4010-9a4

# Vertex AI region for Gemini. Default "global" (broadest availability). Set to a
# region like asia-south1 only if you've confirmed the model is served there.
VERTEX_LOCATION=global

# Gemini is called via Vertex AI using Application Default Credentials
# (`gcloud auth application-default login`) — no API key needed. The old AI
# Studio GEMINI_API_KEY is no longer used by the agent path.
